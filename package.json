{
  "name": "postcss-plugin-px2unit",
  "version": "0.1.0",
  "description": "A PostCSS plugin to convert px to rem, vw, etc.",
  "keywords": [
    "postcss",
    "postcss-plugin",
    "px2rem",
    "px2unit",
    "px2vw"
  ],
  "homepage": "https://github.com/wesmile2020/postcss-plugin-px2unit",
  "bugs": {
    "url": "https://github.com/wesmile2020/postcss-plugin-px2unit/issues"
  },
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wesmile2020/postcss-plugin-px2unit.git"
  },
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/typings/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "types": "./dist/typings/index.d.ts",
      "require": "./dist/index.cjs.js"
    }
  },
  "scripts": {
    "build": "vite build && npm run typings",
    "format": "oxfmt",
    "lint": "oxlint",
    "test": "vitest run",
    "typings": "extract-typings -e src/main.ts -o dist/typings -f index -c"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "extract-typings": "^6.0.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "postcss": "^8.5.15",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
